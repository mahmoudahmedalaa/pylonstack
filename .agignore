# AI Agent Ignore File (.agignore)
# Prevents AI context window bloat by ignoring heavy/generated files

# Dependencies
/node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build Outputs
/.next/
/out/
/build/
/dist/

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# Miscellaneous heavy files
/coverage/
*.log
.DS_Store
